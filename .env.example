NEXT_PUBLIC_APP_NAME=HUB JGG Group
NEXT_PUBLIC_ENV=development
DATA_MODE=mock
DATABASE_URL=postgres://user:password@host:5432/database
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# Auth.js
AUTH_SECRET=gere-uma-chave-secreta-com-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ─── Configuração de IA ──────────────────────────────────────────────
# Escolha o provedor: "openai" ou "openrouter"
# Se não definido, detecta automaticamente pela chave disponível.
AI_PROVIDER=openrouter

# Modelo padrão a usar. Deixe em branco para usar o padrão do provedor.
# Veja TODOS os modelos (incluindo gratuitos) em: https://openrouter.ai/models
# Exemplos OpenAI:    gpt-4o | gpt-4o-mini
# Exemplos OpenRouter pagos:  anthropic/claude-3.5-sonnet | mistralai/mistral-large
# Exemplos OpenRouter FREE:   meta-llama/llama-3.1-8b-instruct:free
#                             google/gemini-2.0-flash-lite:free
#                             microsoft/phi-3-mini-128k-instruct:free
#                             mistralai/mistral-7b-instruct:free
#                             huggingfaceh4/zephyr-7b-beta:free
AI_MODEL=gpt-4o-mini

# OpenAI (necessário para embeddings / pgvector, mesmo usando OpenRouter)
OPENAI_API_KEY=sk-...

# OpenRouter (acesso a Claude, Gemini, Llama, Mistral, DeepSeek etc.)
# Obtenha sua chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
AI_DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# KiloCode AI Gateway (alternativa ao OpenRouter, com os mesmos modelos)
# Obtenha sua chave em: https://kilo.ai — Gateway: https://api.kilo.ai/api/gateway
# Para usar: AI_PROVIDER=kilocode
KILO_API_KEY=kilo-...

# Observability (Sentry)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_AUTH_TOKEN=sntrys_...
