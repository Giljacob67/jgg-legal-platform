# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=HUB JGG Group
NEXT_PUBLIC_ENV=development

# ─── Data Mode ─────────────────────────────────────────────────────
# "mock" = usa dados em memória (para desenvolvimento)
# "real" = conecta ao PostgreSQL (produção/staging)
DATA_MODE=mock

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/database

# ─── Blob Storage ──────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token

# ─── Auth.js ────────────────────────────────────────────────────────
AUTH_SECRET=gere-uma-chave-secreta-com-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ─── Demo Users (DATA_MODE=mock only) ──────────────────────────────────
# Formato JSON array de: { id, email, passwordHash (bcrypt), name, initials, role }
# Para gerar hash bcrypt da senha "jgg2026":
#   node -e "const b=require('bcrypt'); b.hash('jgg2026',12).then(h=>console.log(h))"
# Substitua $2b$12$... pelo hash real gerado acima.
DEMO_USERS_JSON='[{"id":"usr-adv-001","email":"mariana@jgg.com.br","passwordHash":"$2b$12$placeholder_hash_mariana","name":"Mariana Couto","initials":"MC","role":"advogado"},{"id":"usr-soc-001","email":"gilberto@jgg.com.br","passwordHash":"$2b$12$placeholder_hash_gilberto","name":"Gilberto Jacob","initials":"GJ","role":"socio_direcao"},{"id":"usr-adm-001","email":"admin@jgg.com.br","passwordHash":"$2b$12$placeholder_hash_admin","name":"Administrador","initials":"AD","role":"administrador_sistema"}]'

# ─── IA Configuration ───────────────────────────────────────────────
# Escolha o provedor: "openai" | "openrouter" | "kilocode" | "anthropic" | "google"
# Se não definido, detecta automaticamente pela chave disponível.
# Ordem de auto-detecção: kilocode > openrouter > anthropic > google > openai
AI_PROVIDER=openrouter

# Modelo padrão a usar. Deixe em branco para usar o padrão do provedor.
# Exemplos OpenAI:        gpt-4o | gpt-4o-mini | gpt-4.1
# Exemplos OpenRouter:    anthropic/claude-sonnet-4-5 | google/gemini-2.0-flash-001
# Exemplos Anthropic:     claude-sonnet-4-5 | claude-opus-4-5 | claude-haiku-4-5
# Exemplos Google:        gemini-2.0-flash | gemini-2.5-pro-preview-05-06 | gemini-1.5-flash
AI_MODEL=gpt-4o-mini

# OpenAI (necessário para embeddings / pgvector, mesmo usando outro provedor)
OPENAI_API_KEY=sk-your-openai-key

# OpenRouter (acesso a Claude, Gemini, Llama, Mistral, DeepSeek e outros)
# Obtenha sua chave em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-your-openrouter-key

# Anthropic Direto (sem intermediário, ideal para Claude)
# Obtenha sua chave em: https://console.anthropic.com
# Para usar: AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-your-anthropic-key

# Google AI Direto (sem intermediário, ideal para Gemini)
# Obtenha sua chave em: https://aistudio.google.com/apikey
# Para usar: AI_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# KiloCode AI Gateway (alternativa ao OpenRouter, com os mesmos modelos)
# Obtenha sua chave em: https://kilo.ai — Gateway: https://api.kilo.ai/api/gateway
# Para usar: AI_PROVIDER=kilocode
KILO_API_KEY=kilo-your-key

# ─── Observability ──────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_AUTH_TOKEN=sntrys_your-token

# ─── Google Drive Sync (opcional) ───────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/sync/google-drive/callback